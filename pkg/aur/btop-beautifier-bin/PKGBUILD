# Maintainer: M Avdi <mehdi.avdi@gmail.com>
pkgname=btop-beautifier-bin
_pkgname=btop-beautifier
pkgver=0.1.0
pkgrel=1
pkgdesc="Drive CPU, memory, and loopback network in sine-wave patterns to make btop look beautiful (prebuilt binary)"
arch=('x86_64' 'aarch64')
url="https://github.com/mavdi/btop-beautifier"
license=('MIT')
depends=('gcc-libs' 'glibc')
provides=("$_pkgname")
conflicts=("$_pkgname" "$_pkgname-git")

source_x86_64=("$_pkgname-$pkgver-x86_64.tar.xz::$url/releases/download/v$pkgver/$_pkgname-x86_64-unknown-linux-gnu.tar.xz")
source_aarch64=("$_pkgname-$pkgver-aarch64.tar.xz::$url/releases/download/v$pkgver/$_pkgname-aarch64-unknown-linux-gnu.tar.xz")

sha256sums_x86_64=('068ba678f1878b0c08d0aa2648e74b1dee6fbdfbc3c14011d96c4dc65b23278f')
sha256sums_aarch64=('d3d176345ead9cc6ce79a53b2d9038979b78325b05598069104eeb064840b945')

package() {
    if [[ "$CARCH" == "x86_64" ]]; then
        cd "$_pkgname-x86_64-unknown-linux-gnu"
    else
        cd "$_pkgname-aarch64-unknown-linux-gnu"
    fi
    install -Dm755 "$_pkgname" "$pkgdir/usr/bin/$_pkgname"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$_pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
